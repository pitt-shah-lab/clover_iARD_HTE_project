flowchart TD

    subgraph DATA["Data prep (upstream, 02-series)"]
        A1[Raw trial data<br/>DATASET.csv / DERIVED.csv]
        A2[Variable inventory<br/>02b]
        A3[Missingness / QC check<br/>02c]
        A1 --> A2 --> A3
    end

    subgraph SPLIT["Splitting & Imputation"]
        B1["balanced_split.R<br/>allocation_procedure()<br/>covariate-balanced derivation/validation split"]
        B2["missforest_train.R<br/>impute_train_and_save_rfs()<br/>fit + freeze RFs on derivation set"]
        B3["missforest_train.R<br/>impute_test_with_rfs()<br/>apply frozen RFs to validation set"]
        A3 --> B1
        B1 -->|derivation set| B2
        B1 -->|validation set| B3
        B2 -.frozen RFs.-> B3
    end

    subgraph RISK["Risk modeling (05)"]
        C1["rf.risk / rf.risk.10 / logreg.risk<br/>(scoring_methods_v4.R)"]
        B2 --> C1
    end

    subgraph CV["Repeated CV harness"]
        D1["cross_validation.R<br/>oest.cv.fun() / oest.cv.fast()<br/>repeated 50/50 splits within derivation set"]
        D2["scoring_methods_v4.R<br/>~16 CATE/risk learners:<br/>S-/R-/X-learners, ModCov LASSO/ElasticNet,<br/>causal forest (cf.CATE, cf.lin.CATE), BCF"]
        B2 --> D1
        D1 <--> D2
    end

    subgraph POST["Post-processing & evaluation"]
        E1["post_process_v6.R<br/>post.cv.fun()<br/>TOC curves, AUTOC/AUQINI, SE (bootstrap/perturbation)"]
        E2["uplift_fast.R<br/>uplift.fast()<br/>fast ARR/uplift curve"]
        E3["gates_inference.R<br/>gates.fun()<br/>GATES by score quantile,<br/>monotonicity + extreme-bin tests, BLP calibration"]
        E4["michael_q.R<br/>michaelq()<br/>2xK interaction test<br/>(e.g. across quantile bins or sites)"]
        D1 --> E1
        D1 --> E2
        D1 --> E3
        E3 --> E4
    end

    subgraph CONFIRM["Confirmatory analysis (held-out test set)"]
        F1["confirm_analysis.R<br/>confirm_analysis()<br/>classify test patients: benefit / indeterminate / harm<br/>using pre-specified threshold"]
        F2["Outcome test per class<br/>(prop.test: benefit/indet/harm rows)"]
        B3 --> F1
        D2 -.trained models.-> F1
        F1 --> F2
    end

    subgraph OUT["eTables / figures (08_build_etables.R)"]
        G1[eTable 1: variable inventory]
        G2[eTable 2: missingness]
        G3[eTable 3: derivation vs validation balance]
        G4[eTable 4: risk model AUC comparison]
        G5[eTable 5: SOFA/Charlson audit]
        G6["eTable 6: CATE method comparison<br/>(needs E1)"]
        G7["eTable 7: biomarker contribution<br/>(needs E3/E4)"]
        G8["Not yet built:<br/>TOC/uplift figure, GATES forest plot,<br/>calibration plot, confirmatory subgroup table"]
        A2 --> G1
        A3 --> G2
        B1 --> G3
        C1 --> G4
        E1 --> G6
        E3 --> G7
        F2 --> G8
        E1 --> G8
        E3 --> G8
    end

