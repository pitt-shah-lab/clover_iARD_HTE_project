flowchart TD

    subgraph DATA["Data preparation (02-series)"]
        A1[/"Raw trial data<br/>DATASET.csv / DERIVED.csv"\]
        A2[/"Variable inventory · 02b"\]
        A3[/"Missingness / QC check · 02c"\]
        A1 --> A2 --> A3
    end

    subgraph SPLIT["Splitting and imputation (03-04)"]
        B1["03_split_derivation.R<br/>Stratified random 50/50 by arm<br/>seed = 03202026"]
        B2["missforest_train.R · impute_train_and_save_rfs()<br/>Fit and freeze RFs on derivation set"]
        B3["missforest_train.R · impute_test_with_rfs()<br/>Apply frozen RFs to validation set"]
        A3 --> B1
        B1 -->|derivation| B2
        B1 -->|validation| B3
        B2 -.frozen RFs.-> B3
    end

    subgraph RISK["Risk modeling (05)"]
        C1["rf.risk / logreg.risk / enet.risk / bart.risk<br/>Control-arm only · cv_k = 50<br/>Best AUC: enet 0.862"]
        B2 --> C1
    end

    subgraph CV["Repeated CV harness (07)"]
        D1["cross_validation.R · oest.cv.fun()<br/>Repeated 50/50 splits · cv_k = 100"]
        D2["5 CATE learners: cf.CATE, llrf, BCF<br/>pBART, ElasticNet<br/>Two passes: clinical vs +biomarker"]
        B2 --> D1
        D1 <--> D2
    end

    subgraph POST["Post-processing and evaluation (08-09)"]
        E1["post_process_v6.R · post.cv.fun()<br/>TOC curves · AUTOC · AUQINI"]
        E3["gates_inference.R · gates.fun()<br/>GATES · monotonicity · BLP calibration<br/>⚠ 08_gates_inference.R not yet written"]
        E4["michael_q.R · michaelq()<br/>2xK interaction test"]
        D1 --> E1
        D1 --> E3
        E3 --> E4
    end

    subgraph CONFIRM["Confirmatory analysis (10)"]
        F1["confirm_analysis.R · cf.CATE<br/>Trained on derivation applied to validation<br/>Clinical-only + clinical+biomarker"]
        F2["Tertile subgroups<br/>benefit / indeterminate / harm<br/>Result: all p > 0.50 — null finding"]
        B3 --> F1
        D2 -.trained models.-> F1
        F1 --> F2
    end

    subgraph OUT["Publication outputs (09 + 11)"]
        G1["eTable 1: variable inventory"]
        G2["eTable 2: missingness"]
        G3["eTable 3: der vs val balance"]
        G4["eTable 4: risk AUC"]
        G5["eTable 5: SOFA/Charlson audit"]
